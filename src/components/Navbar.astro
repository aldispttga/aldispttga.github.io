<script>
  function initMobileMenu() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const drawer = document.getElementById('mobile-drawer');
    const nav = document.getElementById('drawer-nav');
    const bars = [document.querySelector('.raw-bar-1'), document.querySelector('.raw-bar-2'), document.querySelector('.raw-bar-3')];

    if (!toggleBtn || !drawer) return;

    function toggleMenu(open: boolean) {
      if (open) {
        drawer?.classList.remove('hidden');
        drawer?.classList.add('flex');
        setTimeout(() => {
          drawer?.classList.add('opacity-100');
          nav?.classList.remove('translate-y-4');
        }, 10);
        bars[0]?.classList.add('rotate-45', 'translate-y-[6px]');
        bars[1]?.classList.add('opacity-0');
        bars[2]?.classList.add('-rotate-45', '-translate-y-[6px]');
      } else {
        drawer?.classList.remove('opacity-100');
        nav?.classList.add('translate-y-4');
        bars[0]?.classList.remove('rotate-45', 'translate-y-[6px]');
        bars[1]?.classList.remove('opacity-0');
        bars[2]?.classList.remove('-rotate-45', '-translate-y-[6px]');
        setTimeout(() => {
          drawer?.classList.add('hidden');
          drawer?.classList.remove('flex');
        }, 300);
      }
    }

    toggleBtn.onclick = () => {
      const isOpen = drawer?.classList.contains('flex') && drawer?.classList.contains('opacity-100');
      toggleMenu(!isOpen);
    };

    drawer.querySelectorAll('a').forEach(link => {
      link.onclick = () => {
        toggleMenu(false);
      };
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>